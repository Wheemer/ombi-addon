#!/usr/bin/with-contenv bash
set -e
# shellcheck shell=bash

cat > /tmp/ombi-ingress-nginx.conf <<'NGINX'
events {}

http {
    map $http_x_forwarded_proto $ombi_forwarded_proto {
        default $http_x_forwarded_proto;
        "" $scheme;
    }

    map $http_x_forwarded_host $ombi_forwarded_host {
        default $http_x_forwarded_host;
        "" $host;
    }

    map $http_x_ingress_path $ombi_ingress_prefix {
        default $http_x_ingress_path;
        "" "";
    }

    map $uri $ombi_already_prefixed {
        default 0;
        ~^/api/hassio_ingress/ 1;
    }

    server {
        listen 3579 default_server;

        proxy_buffering off;
        proxy_request_buffering off;
        proxy_http_version 1.1;
        access_log /dev/stdout;
        error_log /dev/stderr info;

        location / {
            set $ombi_upstream_uri $request_uri;

            if ($ombi_ingress_prefix != "") {
                set $ombi_upstream_uri $ombi_ingress_prefix$request_uri;
            }

            if ($ombi_already_prefixed = 1) {
                set $ombi_upstream_uri $request_uri;
            }

            proxy_pass http://127.0.0.1:3578$ombi_upstream_uri;
            proxy_set_header Host $ombi_forwarded_host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $ombi_forwarded_proto;
            proxy_set_header X-Forwarded-Host $ombi_forwarded_host;
            proxy_set_header X-Forwarded-Prefix $http_x_ingress_path;
            proxy_set_header X-Ingress-Path $http_x_ingress_path;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            proxy_redirect ~^(/.*)$ $http_x_ingress_path$1;
        }
    }
}
NGINX

exec nginx -c /tmp/ombi-ingress-nginx.conf -g 'daemon off;'
